{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": "https://repleague.azurewebsites.net",
  "FrontendBaseUrl": "https://repleague.azurewebsites.net",
  "ConnectionStrings": {
    "DefaultConnection": "${CONNECTION_STRING}"
  },
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "RepLeague",
    "Audience": "RepLeagueUsers",
    "ExpirationMinutes": 60,
    "RefreshExpirationDays": 30
  },
  "AzureStorage": {
    "ConnectionString": "${AZURE_STORAGE_CONNECTION_STRING}",
    "ContainerName": "replague-media"
  },
  "SendGrid": {
    "ApiKey": "${SENDGRID_API_KEY}",
    "FromEmail": "soporte@hexacommerce.cl",
    "FromName": "RepLeague"
  },
  "Vapid": {
    "PublicKey": "REPLACE_WITH_YOUR_VAPID_PUBLIC_KEY",
    "PrivateKey": "REPLACE_WITH_YOUR_VAPID_PRIVATE_KEY",
    "Subject": "mailto:admin@repleague.app"
  },
  "AzureTranslator": {
    "Key": "${AZURE_TRANSLATOR_KEY}",
    "Region": "${AZURE_TRANSLATOR_REGION}",
    "Endpoint": "https://api.cognitive.microsofttranslator.com"
  }
}
